# ============================================
# LIFELINE AI - Environment Configuration
# ============================================
# Copy this file to .env and configure with your values

# ============================================
# API KEYS (Required - Get from respective services)
# ============================================

# Google Maps API
GOOGLE_MAPS_API_KEY=AIzaSy...

# Gemini API (Google AI)
GEMINI_API_KEY=AIzaSy...

# OpenAI API
OPENAI_API_KEY=sk-...

# Twilio (SMS & Voice)
TWILIO_ACCOUNT_SID=ACxxx...
TWILIO_AUTH_TOKEN=auth-token-here

# Mapbox (Frontend maps)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ...

# Sentry (Error tracking)
SENTRY_DSN=https://xxx@sentry.io/xxx

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development
PYTHON_ENV=development
DEPLOYMENT_ENVIRONMENT=development  # development|staging|production
DEPLOY_REGION=us-east-1

# ============================================
# DATABASE CONFIGURATION
# ============================================

# MongoDB
MONGODB_USERNAME=admin
MONGODB_PASSWORD=password123
MONGODB_ROOT_USERNAME=admin
MONGODB_ROOT_PASSWORD=password123
MONGODB_REPLICA_SET=rs0
MONGODB_URI=mongodb://admin:password123@mongo:27017/lifeline-dev
MONGODB_TEST_URI=mongodb://admin:password123@mongo:27017/lifeline-test

# Redis
REDIS_PASSWORD=redis123
REDIS_URL=redis://:redis123@redis:6379
REDIS_CACHE_TTL=3600

# ============================================
# BACKEND CONFIGURATION
# ============================================

BACKEND_PORT=3000
BACKEND_URL=http://localhost:3000
API_VERSION=v1
LOG_LEVEL=debug
LOG_FILE_PATH=./logs

# JWT
JWT_SECRET=dev-secret-key-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=604800

# Rate Limiting
RATE_LIMIT_WINDOW=900000  # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_REQUESTS_CRITICAL=10  # For critical endpoints

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=noreply@lifeline.ai
SMTP_FROM_NAME=LifeLine AI

# External Services
AI_SERVICE_URL=http://ai-services:8000
AI_SERVICE_API_KEY=dev-key-change-in-production

# ============================================
# FRONTEND CONFIGURATION
# ============================================

NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# Feature Flags
NEXT_PUBLIC_OFFLINE_MODE=false
NEXT_PUBLIC_VOICE_ENABLED=true
NEXT_PUBLIC_MULTI_LANGUAGE=true

# ============================================
# AI SERVICES CONFIGURATION
# ============================================

AI_SERVICES_PORT=8000
AI_SERVICES_HOST=0.0.0.0
AI_DEBUG_MODE=True

# Models
TRIAGE_MODEL_PATH=./src/models/triage_model.pkl
SYMPTOM_MODEL_PATH=./src/models/symptom_classifier.pkl
HOTSPOT_MODEL_PATH=./src/models/hotspot_detector.pkl

# Feature toggles
ENABLE_COMPLAINT_ANALYTICS=true
ENABLE_HOTSPOT_DETECTION=true
ENABLE_FAKE_EMERGENCY_DETECTION=true

# ============================================
# SERVICE PORTS
# ============================================

BACKEND_PORT=3000
FRONTEND_PORT=3001
AI_SERVICES_PORT=8000
MONGODB_PORT=27017
REDIS_PORT=6379
NGINX_PORT=80
NGINX_HTTPS_PORT=443

# ============================================
# SECURITY
# ============================================

# CORS
CORS_ORIGIN=http://localhost:3001
CORS_CREDENTIALS=true

# HTTPS/SSL
SSL_ENABLED=false
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# API Security
HELMET_ENABLED=true
HELMET_CSP_ENABLED=false  # Set to true in production

# ============================================
# EXTERNAL SERVICES
# ============================================

# Firebase (if using)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-auth-domain.firebaseapp.com

# AWS (if using S3 for backups)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=lifeline-backups

# GCP (if deploying to Google Cloud)
GCP_PROJECT_ID=lifeline-project
GCP_REGION=us-central1

# ============================================
# MONITORING & LOGGING
# ============================================

# Google Cloud Logging
GOOGLE_CLOUD_PROJECT=lifeline-project
GOOGLE_CLOUD_LOGGING_ENABLED=false

# New Relic
NEW_RELIC_ENABLED=false
NEW_RELIC_LICENSE_KEY=your-license-key

# DataDog
DATADOG_ENABLED=false
DATADOG_API_KEY=your-api-key

# ============================================
# DEVELOPMENT ONLY
# ============================================

# Enable hot reload
ENABLE_HOT_RELOAD=true

# Seed test data
SEED_TEST_DATA=false

# Enable API mocking
ENABLE_API_MOCKING=false

# Database reset on startup (DANGEROUS!)
RESET_DATABASE_ON_STARTUP=false

# ============================================
# DEPLOYMENT SPECIFIC
# ============================================

# For staging deployment
STAGING_BACKEND_URL=https://staging-api.lifeline.ai
STAGING_FRONTEND_URL=https://staging.lifeline.ai

# For production deployment
PRODUCTION_BACKEND_URL=https://api.lifeline.ai
PRODUCTION_FRONTEND_URL=https://lifeline.ai

# Database backup settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# ============================================
# FEATURE FLAGS
# ============================================

FEATURE_ACCIDENT_DETECTION=true
FEATURE_BLOOD_NETWORK=true
FEATURE_OFFLINE_MODE=false
FEATURE_VOICE_ASSISTANT=true
FEATURE_PHARMACY_SUPPORT=true

# ============================================
# DEBUG
# ============================================

# Verbose logging
DEBUG=lifeline:*

# Enable debug panel
SHOW_DEBUG_PANEL=false

# Mock external APIs (for testing)
MOCK_MAPS_API=false
MOCK_GEMINI_API=false

# ============================================
# END OF CONFIGURATION
# ============================================
