[flake8]
max-line-length = 100
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    docs/source/conf.py,
    old/long_history.py,
    build,
    dist,
    .venv,
    venv,
    .eggs,
    *.egg,
    .tox,
    .mypy_cache,
    .pytest_cache,
    __pycache__

per-file-ignores =
    __init__.py:F401,F403
    tests/*:F401,F811,E501

count = True
statistics = True
